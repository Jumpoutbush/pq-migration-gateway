# Build parameters can be overridden at build time.
OPENSSL_VERSION=3.5.0
NGINX_VERSION=1.28.0
MAKE_JOBS=4

# Runtime services are configured in config/services.json.
SERVICES_CONFIG=/etc/pq-gateway/config/services.json

# Enterprise initialization writes the real values to .env.enterprise.
# Keep Manager operator credentials separate from Runtime Agent credentials.
# MANAGER_API_TOKEN=<generated-by-make-enterprise-init>
# RUNTIME_AGENT_TOKEN=<generated-by-make-enterprise-init>

# Runtime Agent defaults. A remote Manager URL must use HTTPS unless an
# isolated test explicitly opts into insecure HTTP.
PQ_MANAGER_API_URL=http://127.0.0.1:18080
PQ_RUNTIME_AGENT_ID=enterprise-runtime-agent-1
PQ_RUNTIME_AGENT_INTERVAL=30
PQ_RUNTIME_EBPF_DURATION=5
PQ_RUNTIME_EBPF_MAX_PROBES=64
PQ_RUNTIME_EBPF_PROC_ROOT=/proc
PQ_RUNTIME_CGROUP_ROOT=/sys/fs/cgroup
