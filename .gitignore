# Generated keys and certificates. Do not commit real secrets.
certs/*.key
certs/*.crt
certs/*.csr
certs/*.srl
certs/*.ext
/certs/**/*.key
/certs/**/*.crt
/certs/**/*.csr
/certs/**/*.srl
certs/mldsa-demo/

# Generated scans, databases, and experiments.
crypto-inventory.json
crypto-inventory.csv
tls-inventory.json
tls-inventory.csv
risk-report.json
*.db
experiment-results/

# Runtime/editor.
.env
__pycache__/
*.pyc
.DS_Store

# Runtime logs
/runtime-data/logs/*
!/runtime-data/logs/.gitkeep

# Prometheus and historical metrics
/runtime-data/metrics/*
!/runtime-data/metrics/.gitkeep

# Scanner snapshots and discovered assets
/runtime-data/scans/*
!/runtime-data/scans/.gitkeep

# Control-plane database, releases and agent state
/runtime-data/control/*
!/runtime-data/control/.gitkeep

# Future runtime directories
/runtime-data/audit/*
!/runtime-data/audit/.gitkeep

/runtime-data/certificates/*
!/runtime-data/certificates/.gitkeep

/runtime-data/alerts/*
!/runtime-data/alerts/.gitkeep

# Enterprise runtime data
/runtime-data/enterprise/*
!/runtime-data/enterprise/.gitkeep

# SQLite side files
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Enterprise local configuration and secrets
/.env.enterprise
/customer-service.json
/config/enterprise/services.json